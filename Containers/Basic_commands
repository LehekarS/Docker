# 1. Run a Container
docker run <image-name>
# Creates and starts a container from the specified image.

# 2. List Running Containers
docker ps
# Displays a list of currently running containers.

# 3. List All Containers (Including Stopped)
docker ps -a
# Shows all containers, including stopped ones.

# 4. Stop a Running Container
docker stop <container-id>
# Stops a running container.

# 5. Start a Stopped Container
docker start <container-id>
# Starts a container that was previously stopped.

# 6. Restart a Container
docker restart <container-id>
# Restarts a running container.

# 7. Remove a Container
docker rm <container-id>
# Deletes a stopped container.

# 8. View Logs of a Container
docker logs <container-id>
# Displays logs generated by the container.

# 9. Execute a Command Inside a Running Container
docker exec -it <container-id> <command>
# Executes a command inside a running container. Example: `docker exec -it <container-id> bash` to open a bash shell.

# 10. Inspect Container Details
docker inspect <container-id>
# Shows detailed information about the container.

# 11. Monitor Resource Usage of Containers
docker stats
# Displays real-time resource usage (CPU, memory, etc.) of running containers.

# 12. Stop All Running Containers
docker stop $(docker ps -q)
# Stops all currently running containers.

# 13. Remove All Stopped Containers
docker rm $(docker ps -a -q)
# Removes all stopped containers.

